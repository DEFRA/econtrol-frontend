{% extends 'layouts/page.njk' %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    {% if error %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" data-govuk-error-summary-init="">
      <div role="alert">
        <h2 class="govuk-error-summary__title">
          There is a problem
        </h2>
        <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li>
                <a href="#permitReferences">Enter at least one permit number</a>
              </li>
            </ul>
        </div>
      </div>
    </div>
    {% endif %}

    <h1 class="govuk-heading-xl">
      Search for CITES permits
    </h1>

    <form method="post" action="/search-results">

      <div class="govuk-form-group{{" govuk-form-group--error" if error}}">
        <label class="govuk-label govuk-label--m" for="permitReferences">
          Enter the permit numbers you want to process
        </label>

        <div id="permitReferences-hint" class="govuk-hint">
          Each permit number must be on a new line.
        </div>
        {% if error %}
        <p id="permitReferences-error" class="govuk-error-message">
          <span class="govuk-visually-hidden">Error:</span> Enter at least one permit number
        </p>
        {% endif %}
        <textarea class="govuk-textarea{{" govuk-textarea--error" if error}}" id="permitReferences" name="permitReferences" rows="10" aria-describedby="permitReferences-hint{{" permitReferences-error" if error}}"></textarea>
      </div>

      <p id="permitCount" class="govuk-body-s govuk-!-margin-top-1" aria-live="polite" aria-atomic="true"></p>

      <button type="submit" name="search" class="govuk-button" data-module="govuk-button">
        Search for permits
      </button>

    </form>
  </div>
</div>

{% endblock %}
